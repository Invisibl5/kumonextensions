{
  "manifest_version": 3,
  "name": "Class-Navi+",
  "version": "0.6.1",
  "description": "Kumon Class-Navi: Tools & Upgrades",
  "author": "Invisibl5",
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://class-navi.digital.kumon.com/*",
    "https://instructor2.digital.kumon.com/*",
    "https://*.digital.kumon.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://class-navi.digital.kumon.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://class-navi.digital.kumon.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
